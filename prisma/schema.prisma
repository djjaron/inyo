generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String?
  name      String?
  familyId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  family    Family?  @relation(fields: [familyId], references: [id])

  @@map("users")
}

model Family {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  tier        String   @default("standard")
  aum         Float?
  currency    String   @default("USD")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       User[]
  entities    Entity[]
  deals       Deal[]
  contacts    Contact[]
  documents   Document[]
  agentRuns   AgentRun[]
  approvals   Approval[]
  spvs          SPV[]

  @@map("families")
}

model Entity {
  id          String    @id @default(cuid())
  familyId    String
  name        String
  type        String    // llc, lp, trust, corp, foundation, individual
  jurisdiction String?
  taxId       String?
  description String?
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  family      Family    @relation(fields: [familyId], references: [id])
  deals       Deal[]
  cashFlows   CashFlow[]

  @@map("entities")
}

model Deal {
  id              String   @id @default(cuid())
  familyId        String
  entityId        String?
  name            String
  company         String
  sector          String?
  stage           String?  // pre-seed, seed, series-a, series-b, growth, pe, real-estate, credit
  status          String   @default("inbound") // inbound, reviewing, diligence, ic-review, passed, invested, archived
  capitalAsk      Float?
  valuation       Float?
  ownership       Float?
  description     String?
  sourceType      String?  // inbound, network, broker, lp-intro
  sourceContact   String?
  dealScore       Int?
  icMemoUrl       String?
  dataRoomUrl     String?
  pitchDeckUrl    String?
  website           String?
  linkedinUrl       String?
  crunchbaseUrl     String?
  affinityScore     Float?
  riskScore         Float?
  fundabilityScore  Float?
  enrichedAt        DateTime?
  investedAt        DateTime?
  deletedAt         DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  family          Family   @relation(fields: [familyId], references: [id])
  entity          Entity?  @relation(fields: [entityId], references: [id])
  documents       Document[]
  aiAnalyses      AIAnalysis[]
  contacts        DealContact[]
  founders        Founder[]
  spvs            SPV[]

  @@map("deals")
}

model DealContact {
  id        String  @id @default(cuid())
  dealId    String
  contactId String
  role      String? // founder, advisor, lead-investor, co-investor

  deal      Deal    @relation(fields: [dealId], references: [id])
  contact   Contact @relation(fields: [contactId], references: [id])

  @@unique([dealId, contactId])
  @@map("deal_contacts")
}

model PortfolioCompany {
  id              String    @id @default(cuid())
  familyId        String?
  name            String
  sector          String?
  stage           String?
  status          String    @default("active") // active, exited, written-off, watchlist
  investedAmount  Float?
  currentValue    Float?
  ownership       Float?
  investedAt      DateTime?
  lastFundingDate DateTime?
  lastFundingRound String?
  website         String?
  description     String?
  alertLevel      String    @default("normal") // normal, watch, alert, critical
  deletedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  alerts          PortfolioAlert[]
  documents       Document[]
  aiAnalyses      AIAnalysis[]

  @@map("portfolio_companies")
}

model PortfolioAlert {
  id          String   @id @default(cuid())
  companyId   String
  type        String   // funding, executive-departure, layoffs, press, legal, burn-rate
  severity    String   @default("info") // info, warning, critical
  title       String
  body        String?
  source      String?
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())

  company     PortfolioCompany @relation(fields: [companyId], references: [id])

  @@map("portfolio_alerts")
}

model Contact {
  id            String   @id @default(cuid())
  familyId      String
  name          String
  email         String?
  phone         String?
  company       String?
  title         String?
  type          String   @default("contact") // founder, lp, gp, attorney, banker, advisor, broker, family
  linkedIn      String?
  notes         String?
  lastContactAt DateTime?
  introducedBy  String?
  warmPathNotes     String?
  investorType      String?   // lp, co-investor, family-office, vc, pe, angel, strategic
  assetClasses      String[]  // ["tech", "real-estate", "sports", "credit", "pe", "other"]
  checkSizeMin      Float?
  checkSizeMax      Float?
  portfolioNotes    String?
  lastDealTogether  String?
  deletedAt         DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  family        Family   @relation(fields: [familyId], references: [id])
  deals         DealContact[]
  interactions  Interaction[]
  documents     Document[]

  @@map("contacts")
}

model Interaction {
  id          String   @id @default(cuid())
  contactId   String
  type        String   // email, call, meeting, note, intro
  subject     String?
  notes       String?
  outcome     String?
  occurredAt  DateTime @default(now())
  createdAt   DateTime @default(now())

  contact     Contact  @relation(fields: [contactId], references: [id])

  @@map("interactions")
}

model Document {
  id          String    @id @default(cuid())
  familyId    String
  dealId      String?
  companyId   String?
  contactId   String?
  name        String
  type        String    // pitch-deck, ic-memo, nda, lpa, safe, k1, tax-doc, bank-statement, report, contract, other
  mimeType    String?
  storageUrl  String?
  textContent String?
  checksum    String?
  fileSize    Int?
  processed   Boolean   @default(false)
  expiresAt   DateTime?
  keyDates    Json?     // [{ label: string, date: string, type: "expiry"|"deadline"|"closing"|"renewal" }]
  alertDays   Int?      @default(30)  // days before expiry to show warning
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  family      Family    @relation(fields: [familyId], references: [id])
  deal        Deal?     @relation(fields: [dealId], references: [id])
  company     PortfolioCompany? @relation(fields: [companyId], references: [id])
  contact     Contact?  @relation(fields: [contactId], references: [id])
  aiAnalyses  AIAnalysis[]
  versions    DocumentVersion[]

  @@map("documents")
}

model DocumentVersion {
  id          String   @id @default(cuid())
  documentId  String
  document    Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  name        String
  textContent String?
  checksum    String?
  mimeType    String?
  createdAt   DateTime @default(now())

  @@map("document_versions")
}

model CashFlow {
  id          String    @id @default(cuid())
  entityId    String
  type        String    // income, expense, distribution, capital-call, tax-payment
  category    String?
  amount      Float
  currency    String    @default("USD")
  description String?
  occurredAt  DateTime
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())

  entity      Entity    @relation(fields: [entityId], references: [id])

  @@map("cash_flows")
}

model AIAnalysis {
  id           String   @id @default(cuid())
  agentType    String   // deal-flow, ic-memo, portfolio-monitor, cfo, legal, tax, chief-of-staff
  dealId       String?
  companyId    String?
  documentId   String?
  input        Json
  output       Json
  model        String?
  tokensUsed   Int?
  status       String   @default("completed") // pending, running, completed, failed
  createdAt    DateTime @default(now())

  deal         Deal?            @relation(fields: [dealId], references: [id])
  company      PortfolioCompany? @relation(fields: [companyId], references: [id])
  document     Document?        @relation(fields: [documentId], references: [id])

  @@map("ai_analyses")
}

model AgentRun {
  id          String   @id @default(cuid())
  familyId    String
  agentType   String
  status      String   @default("pending") // pending, running, awaiting-approval, completed, failed
  input       Json
  output      Json?
  error       String?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime @default(now())

  family      Family   @relation(fields: [familyId], references: [id])
  approvals   Approval[]

  @@map("agent_runs")
}

model Approval {
  id          String   @id @default(cuid())
  familyId    String
  agentRunId  String?
  type        String   // agent-action, document-sign, transaction, deal-advance
  title       String
  description String?
  status      String   @default("pending") // pending, approved, rejected
  priority    String   @default("normal") // low, normal, high, urgent
  reviewedAt  DateTime?
  reviewNote  String?
  createdAt   DateTime @default(now())

  family      Family   @relation(fields: [familyId], references: [id])
  agentRun    AgentRun? @relation(fields: [agentRunId], references: [id])

  @@map("approvals")
}

model Founder {
  id          String    @id @default(cuid())
  dealId      String
  deal        Deal      @relation(fields: [dealId], references: [id], onDelete: Cascade)
  name        String
  title       String?
  linkedinUrl String?
  bio         String?
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("founders")
}

model AuditLog {
  id           String   @id @default(cuid())
  familyId     String?
  action       String   // create, update, delete, restore
  resourceType String   // document, deal, contact, entity, cashflow, founder
  resourceId   String
  resourceName String?
  diff         Json?    // { before: {...}, after: {...} } — optional snapshot
  performedBy  String?  // userId or "system"
  createdAt    DateTime @default(now())

  @@map("audit_logs")
}

model SPV {
  id              String    @id @default(cuid())
  familyId        String
  dealId          String?
  name            String
  status          String    @default("draft")   // draft, launching, active, closed, cancelled
  spvType         String    @default("syndicate") // syndicate, secondary, layered
  sydecarId       String?   // ID returned by Sydecar API
  sydecarUrl      String?   // Link to Sydecar dashboard for this SPV
  targetRaise     Float?
  totalCommitted  Float?    @default(0)
  managementFee   Float?    @default(2)   // percentage e.g. 2.0 = 2%
  carry           Float?    @default(20)  // percentage e.g. 20.0 = 20%
  closingDate     DateTime?
  investmentType  String?   // equity, convertible-note, safe, debt
  description     String?
  launchedAt      DateTime?
  deletedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  family    Family       @relation(fields: [familyId], references: [id])
  deal      Deal?        @relation(fields: [dealId], references: [id])
  investors SPVInvestor[]

  @@map("spvs")
}

model SPVInvestor {
  id            String    @id @default(cuid())
  spvId         String
  spv           SPV       @relation(fields: [spvId], references: [id], onDelete: Cascade)
  contactId     String?
  name          String
  email         String
  commitment    Float     @default(0)
  status        String    @default("invited")   // invited, committed, funded, withdrawn
  sydecarPersonId String? // Person ID from Sydecar
  sydecarProfileId String? // Profile ID from Sydecar
  invitedAt     DateTime?
  committedAt   DateTime?
  fundedAt      DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("spv_investors")
}
